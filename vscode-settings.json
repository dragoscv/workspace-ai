{
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "git.confirmSync": false,
  "editor.wordWrap": "on",
  "window.title": "Dragos: ${rootName}${separator}${dirty}${activeEditorShort}${separator}${appName}",
  "workbench.colorTheme": "Just Black 2",
  "editor.suggestSelection": "first",
  "editor.inlineSuggest.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "editor.linkedEditing": true,
  "editor.matchBrackets": "never",
  "javascript.referencesCodeLens.showOnAllFunctions": true,
  "typescript.referencesCodeLens.showOnAllFunctions": true,
  "diffEditor.codeLens": true,
  "javascript.referencesCodeLens.enabled": true,
  "typescript.implementationsCodeLens.enabled": true,
  "typescript.referencesCodeLens.enabled": true,
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "editor.stickyScroll.enabled": true,
  "[javascriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "vscode.typescript-language-features",
  "editor.accessibilitySupport": "off",
  "diffEditor.ignoreTrimWhitespace": false,
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "docker-desktop"
  ],
  "remote.portsAttributes": {
    "3000": {
      "protocol": "http"
    }
  },
  "files.autoSave": "afterDelay",
  "github.copilot.enable": {
    "*": true
  },
  "github.copilot.selectedCompletionModel": "gpt-4o-copilot",
  "github.copilot.chat.agent.runTasks": true,
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.agent.currentEditorContext.enabled": true,
  "github.copilot.chat.languageContext.typescript.cacheTimeout": 5000,
  "github.copilot.chat.setupTests.enabled": true,
  "github.copilot.advanced": {
    "enableExperimentalFeatures": true,
    "enableExperimentalCodeGen": true,
    "enableExperimentalChat": true,
    "enableExperimentalEdits": true,
    "enableExperimentalSearch": true,
    "indentationMode": {
      "*": "tabsWithSpaces",
      "typescript": "tabsWithSpaces",
      "typescriptreact": "tabsWithSpaces"
    }
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "chat.instructionsFilesLocations": {
    "E:/GitHub/workspace-ai/.github/instructions/": true,
    "E:/GitHub/workspace-ai/.github/instructions/initial.instructions.md": true,
    "E:/GitHub/workspace-ai/.github/instructions/general.instructions.md": true,
    "E:/GitHub/workspace-ai/.github/instructions/context-aware-selector.instructions.md": true,
    "E:/GitHub/workspace-ai/.github/instructions/orchestrator.instructions.md": true,
    "E:/GitHub/workspace-ai/.github/instructions/memory-mcp-usage.instructions.md": true,
    "E:/GitHub/workspace-ai/.github/instructions/mcp-usage.instructions.md": true,
    "E:/GitHub/workspace-ai/.github/instructions/multi-agent-coordination.instructions.md": true,
    "E:/GitHub/workspace-ai/.github/instructions/templates-and-decision-trees.instructions.md": true,
    "e:/GitHub/codai-project/.github/instructions/": true,
    "e:/GitHub/codai-project/.github/instructions/initial.instructions.md": true,
    "e:/GitHub/codai-project/.github/instructions/mcp-usage.instructions.md": true
  },
  "chat.promptFilesLocations": {
    ".github/prompts": true,
    "E:/GitHub/workspace-ai/.github/prompts": true
  },
  "chat.modeFilesLocations": {
    ".github/chatmodes": true,
    "E:/GitHub/workspace-ai/.github/chatmodes": true
  },
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".github/instructions/commit-guidelines.instructions.md"
    },
    {
      "file": "E:/GitHub/workspace-ai/.github/instructions/development/commit-guidelines.instructions.md"
    },
    {
      "file": "e:/GitHub/codai-project/.github/instructions/initial.instructions.md"
    }
  ],
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "file": ".github/instructions/code-review.instructions.md"
    },
    {
      "file": "E:/GitHub/workspace-ai/.github/instructions/development/code-review.instructions.md"
    },
    {
      "file": "e:/GitHub/codai-project/.github/instructions/mcp-usage.instructions.md"
    }
  ],
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    {
      "file": ".github/instructions/pr-guidelines.instructions.md"
    },
    {
      "file": "E:/GitHub/workspace-ai/.github/instructions/development/pr-guidelines.instructions.md"
    }
  ],
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.chat.startDebugging.enabled": true,
  "github.copilot.chat.summarizeAgentConversationHistory.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.completionContext.typescript.mode": "on",
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "chat.edits2.enabled": true,
  "chat.tools.autoApprove": true,
  "inlineChat.enableV2": true,
  "terminal.integrated.suggest.enabled": true,
  "workbench.iconTheme": "vscode-icons",
  "terminal.integrated.enableVisualBell": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "pwsh": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe"
    }
  },
  "terminal.explorerKind": "external",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "block",
  "terminal.integrated.cursorWidth": 2,
  "terminal.integrated.middleClickBehavior": "paste",
  "terminal.integrated.tabs.defaultColor": "terminal.ansiGreen",
  "terminal.integrated.rightClickBehavior": "default",
  "files.watcherExclude": {
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/node_modules": true
  },
  "typescript.tsserver.maxTsServerMemory": 4096,
  "vsicons.dontShowNewVersionMessage": true,
  "extensions.ignoreRecommendations": true,
  "task.verboseLogging": true,
  "problems.showCurrentInStatus": true,
  "github.copilot.chat.agent.terminal.denyList": {},
  "githubPullRequests.experimental.chat": true,
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.chat.notebook.followCellExecution.enabled": true
}
