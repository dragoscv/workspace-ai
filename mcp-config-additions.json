{
  "mcpServers": {
    "awslabs.aws-api-mcp-server": {
      "command": "awslabs.aws-api-mcp-server",
      "args": [],
      "env": {
        "AWS_PROFILE": "your-aws-profile",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "INFO"
      },
      "disabled": false,
      "autoApprove": [
        "call_aws",
        "suggest_aws_commands"
      ]
    },
    "awslabs.amazon-rekognition-mcp-server": {
      "command": "awslabs.amazon-rekognition-mcp-server",
      "args": [],
      "env": {
        "AWS_PROFILE": "your-aws-profile",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "INFO"
      },
      "disabled": false,
      "autoApprove": [
        "detect_labels",
        "detect_faces",
        "detect_text",
        "detect_celebrities",
        "detect_unsafe_content"
      ]
    },
    "awslabs.aws-support-mcp-server": {
      "command": "awslabs.aws-support-mcp-server",
      "args": [],
      "env": {
        "AWS_PROFILE": "your-aws-profile",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "INFO"
      },
      "disabled": false,
      "autoApprove": [
        "create_case",
        "list_cases",
        "get_case",
