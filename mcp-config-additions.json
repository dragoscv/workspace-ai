    "awslabs.ecs-mcp-server": {
      "command": "ecs-mcp-server",
      "args": [],
      "env": {
        "AWS_PROFILE": "your-aws-profile",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "INFO",
        "ALLOW_WRITE": "false"
